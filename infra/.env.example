# =============================================================================
# AZALPLUS - Variables d'environnement
# =============================================================================
# Copier ce fichier vers .env et remplir les valeurs

# -----------------------------------------------------------------------------
# Environnement
# -----------------------------------------------------------------------------
AZALPLUS_ENV=development  # development | staging | production

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------
DB_PASSWORD=your_secure_password_here

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=your_redis_password_here

# -----------------------------------------------------------------------------
# Sécurité (OBLIGATOIRE en production)
# -----------------------------------------------------------------------------
# Générer avec: openssl rand -hex 32
SECRET_KEY=your_secret_key_minimum_32_characters

# Générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key

# -----------------------------------------------------------------------------
# Email SMTP
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=AZALPLUS <noreply@example.com>

# -----------------------------------------------------------------------------
# IA (optionnel)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...

# -----------------------------------------------------------------------------
# Paiements (optionnel)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_...
STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Stockage (optionnel)
# -----------------------------------------------------------------------------
S3_BUCKET=azalplus-files
S3_ACCESS_KEY=...
S3_SECRET_KEY=...
S3_ENDPOINT=https://s3.amazonaws.com
