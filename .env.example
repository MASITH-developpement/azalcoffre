# =============================================================================
# AZALPLUS - Configuration Environnement
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=AZALPLUS
APP_ENV=development
# development | staging | production
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_SECRET_KEY=your-secret-key-min-32-chars-change-in-production

# Créateur (accès dashboard Guardian)
CREATEUR_EMAIL=admin@azalplus.fr

# -----------------------------------------------------------------------------
# BASE DE DONNÉES
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://azalplus:azalplus@localhost:5432/azalplus
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# REDIS (Cache & Sessions)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# SÉCURITÉ
# -----------------------------------------------------------------------------
# JWT
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_AUTHENTICATED=500
RATE_LIMIT_PUBLIC=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# 💰 FINTECTURE (Open Banking - Paiements)
# -----------------------------------------------------------------------------
# https://console.fintecture.com
FINTECTURE_APP_ID=
FINTECTURE_APP_SECRET=
FINTECTURE_PRIVATE_KEY=
# Clé privée RSA au format PEM (une seule ligne avec \n)
# Exemple: -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
FINTECTURE_WEBHOOK_SECRET=
FINTECTURE_ENVIRONMENT=sandbox
# sandbox | production

# Commission AZALPLUS sur paiements (en plus de Fintecture 0.99%)
FINTECTURE_COMMISSION_PCT=0.30

# -----------------------------------------------------------------------------
# 💰 SWAN (Banking as a Service)
# -----------------------------------------------------------------------------
# https://dashboard.swan.io
SWAN_CLIENT_ID=
SWAN_CLIENT_SECRET=
SWAN_PROJECT_ID=
SWAN_WEBHOOK_SECRET=
SWAN_ENVIRONMENT=sandbox
# sandbox | production

# Tarification compte bancaire
SWAN_MONTHLY_FEE=9.90
SWAN_TAP_TO_PAY_PCT=1.20

# -----------------------------------------------------------------------------
# 📱 TWILIO (SMS & Téléphonie)
# -----------------------------------------------------------------------------
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Format E.164: +33123456789
TWILIO_WHATSAPP_NUMBER=
# Format: +33123456789 (numéro WhatsApp Business)
TWILIO_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# 📦 TRANSPORTEURS
# -----------------------------------------------------------------------------

# Colissimo (La Poste)
# https://www.colissimo.entreprise.laposte.fr
COLISSIMO_CONTRACT_NUMBER=
COLISSIMO_PASSWORD=
COLISSIMO_SENDER_REF=

# Chronopost
# https://www.chronopost.fr/fr/espace-client
CHRONOPOST_ACCOUNT_NUMBER=
CHRONOPOST_PASSWORD=
CHRONOPOST_SUB_ACCOUNT=

# Mondial Relay
# https://www.mondialrelay.fr/espace-pro
MONDIAL_RELAY_MERCHANT_ID=
MONDIAL_RELAY_API_KEY=

# DHL Express
# https://developer.dhl.com
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=

# UPS
# https://developer.ups.com
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=

# -----------------------------------------------------------------------------
# 🤖 IA (Autocomplétion, Répondeur, Secrétariat)
# -----------------------------------------------------------------------------

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Modèle par défaut pour l'autocomplétion
AI_DEFAULT_MODEL=claude-haiku
# claude-haiku | claude-sonnet | gpt-4o-mini | gpt-4o

AI_TEMPERATURE=0.3
AI_MAX_TOKENS=1000

# -----------------------------------------------------------------------------
# 📧 EMAIL
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@azalplus.fr
SMTP_FROM_NAME=AZALPLUS
SMTP_USE_TLS=true

# SendGrid (alternative)
SENDGRID_API_KEY=

# -----------------------------------------------------------------------------
# 📁 STOCKAGE (Fichiers, GED)
# -----------------------------------------------------------------------------
STORAGE_DRIVER=local
# local | s3 | gcs | azure

# Local
STORAGE_LOCAL_PATH=/var/azalplus/storage

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=azalplus-files

# Google Cloud Storage
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_CREDENTIALS_JSON=

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER=

# -----------------------------------------------------------------------------
# 🔍 OCR (Extraction factures)
# -----------------------------------------------------------------------------
OCR_PROVIDER=google
# google | aws | azure | tesseract

# Google Vision
GOOGLE_VISION_CREDENTIALS=

# AWS Textract
AWS_TEXTRACT_REGION=eu-west-1

# -----------------------------------------------------------------------------
# 📊 MONITORING
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Logging
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json
# json | text

# -----------------------------------------------------------------------------
# 🌐 SERVICES EXTERNES
# -----------------------------------------------------------------------------

# API Sirene (INSEE) - Lookup entreprises
INSEE_API_KEY=
# https://api.insee.fr

# API Adresse (data.gouv.fr) - Autocomplétion adresses
# Pas de clé nécessaire

# API TVA (VIES) - Validation numéros TVA
# Pas de clé nécessaire

# API BAN (Base Adresse Nationale)
# Pas de clé nécessaire

# -----------------------------------------------------------------------------
# 🔐 AUTHENTIFICATION EXTERNE (SSO)
# -----------------------------------------------------------------------------

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Azure AD
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# -----------------------------------------------------------------------------
# 📱 NOTIFICATIONS PUSH
# -----------------------------------------------------------------------------

# Firebase Cloud Messaging
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# -----------------------------------------------------------------------------
# 🧪 TESTS
# -----------------------------------------------------------------------------
TEST_DATABASE_URL=postgresql://azalplus:azalplus@localhost:5432/azalplus_test
TEST_REDIS_URL=redis://localhost:6379/1
